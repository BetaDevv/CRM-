# ─── Base de Datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tbs_crm

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-en-produccion-usa-una-clave-larga-y-aleatoria

# ─── LinkedIn OAuth2 ──────────────────────────────────────────────────────────
# Crea tu app en: https://www.linkedin.com/developers/apps
# Scopes necesarios: r_organization_social, rw_organization_admin, r_basicprofile
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3001/api/oauth/linkedin/callback

# ─── Meta (Facebook + Instagram) ─────────────────────────────────────────────
# Crea tu app en: https://developers.facebook.com/apps
# Scopes: pages_read_engagement, pages_show_list, instagram_basic, instagram_manage_insights
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/oauth/meta/callback

# ─── TikTok Business ──────────────────────────────────────────────────────────
# Solicita acceso en: https://business-api.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3001/api/oauth/tiktok/callback

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Crea credenciales OAuth2 en: https://console.cloud.google.com/
# Habilita: Google Analytics Data API
GA4_CLIENT_ID=
GA4_CLIENT_SECRET=
GA4_REDIRECT_URI=http://localhost:3001/api/oauth/ga4/callback

# ─── Google Calendar OAuth ───────────────────────────────────────────────────
# Usa las mismas credenciales OAuth2 de Google Cloud Console
# Habilita: Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/oauth/callback

# ─── Microsoft Calendar (Outlook) ──────────────────────────────────────────
# Crea una app en: https://portal.azure.com → App Registrations
# Permisos necesarios: Calendars.ReadWrite, offline_access, User.Read
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/calendar/microsoft/callback

# ─── SMTP (Notificaciones por email) ─────────────────────────────────────────
# Para Gmail: usa una App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
